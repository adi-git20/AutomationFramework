<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Automation Suite" parallel="tests" thread-count="2">

    <!-- 🔷 Chrome Execution -->
    <test name="Chrome Tests" parallel="classes" thread-count="3">
        <parameter name="browser" value="chrome"/>

        <classes>
            <class name="Tests.BookingFirstTest"/>
            <class name="Tests.FirstTest"/>
            <class name="Tests.urlTest"/>
            <class name="Tests.ActionTest"/>
            <class name="Tests.WindowTest"/>
            <class name="Tests.GoogleTest"/>
            <class name="Tests.NavigationTest"/>
            <class name="Tests.BookingTest"/>
        </classes>
    </test>

    <!-- 🔷 Firefox Execution -->
    <test name="Firefox Tests" parallel="classes" thread-count="3">
        <parameter name="browser" value="firefox"/>

        <classes>
            <class name="Tests.BookingFirstTest"/>
            <class name="Tests.FirstTest"/>
            <class name="Tests.urlTest"/>
            <class name="Tests.ActionTest"/>
            <class name="Tests.WindowTest"/>
            <class name="Tests.GoogleTest"/>
            <class name="Tests.NavigationTest"/>
            <class name="Tests.BookingTest"/>
        </classes>
    </test>

</suite>